# Routing-data classes — pure data carriers (`serviceinfo`,
# `eventgroupinfo`, `event`, `remote_subscription`) handed around as
# `shared_ptr<>` by the SD `host` callback surface. They live in
# `implementation/routing/src/` for historical reasons but have no
# routing-manager dependency, so they belong in core.
#
# `event.cpp` includes its constructor. That constructor calls
# `runtime::get()->create_notification()`, and `runtime_impl`'s
# `create_notification` lives in `VSOMEIP_CORE_RUNTIME_SRCS` below — so it
# resolves inside core without pulling in the routing manager.
VSOMEIP_CORE_ROUTING_DATA_SRCS = [
    "implementation/routing/src/event.cpp",
    "implementation/routing/src/eventgroupinfo.cpp",
    "implementation/routing/src/remote_subscription.cpp",
    "implementation/routing/src/serviceinfo.cpp",
]

# The `runtime`/`runtime_impl` singleton plus its message and payload
# factories. These live in core so that `libvsomeip3-core.so` is a
# self-contained SOME/IP framing library — anything above the wire that
# needs `runtime::get()->create_payload()` / `create_notification()` /
# `create_message()` (e.g. `message_impl::message_impl`, `event::event`)
# resolves inside core.
#
# The application-related methods on `runtime_impl` (create_application /
# get_application / remove_application) also have their vtable slots
# defined here, but their bodies forward through
# `internal::application_factory` — an interface whose implementation is
# provided by `runtime_impl_apps.cpp` in the routing layer, and installed
# into core at library-load time. An SD-only host that never links
# libvsomeip3.so has no factory installed, and calling create_application
# throws std::logic_error. See
# `implementation/runtime/include/application_factory.hpp`.
VSOMEIP_CORE_RUNTIME_SRCS = [
    "implementation/runtime/src/runtime.cpp",
    "implementation/runtime/src/runtime_impl.cpp",
]

VSOMEIP_CORE_SRCS = (
    VSOMEIP_CORE_ENDPOINTS_SRCS +
    VSOMEIP_CORE_LOGGER_SRCS +
    VSOMEIP_CORE_MESSAGE_SRCS +
    VSOMEIP_CORE_PLUGIN_SRCS +
    VSOMEIP_CORE_PROTOCOL_SRCS +
    VSOMEIP_CORE_SECURITY_SRCS +
    VSOMEIP_CORE_TRACING_SRCS +
    VSOMEIP_CORE_UTILITY_SRCS +
    VSOMEIP_CORE_ROUTING_DATA_SRCS +
    VSOMEIP_CORE_RUNTIME_SRCS
)

# -----------------------------------------------------------------------------
# Routing-layer sources — added on top of vsomeip-core to form vsomeip-lib
# -----------------------------------------------------------------------------

# Local/UDS IPC endpoints + peer-credential check + netlink + the endpoint
# manager (base + impl). These exist only inside a routing-manager process.
VSOMEIP_ROUTING_LAYER_ENDPOINTS_SRCS = [
    "implementation/endpoints/src/credentials.cpp",
    "implementation/endpoints/src/endpoint_manager_base.cpp",
    "implementation/endpoints/src/endpoint_manager_impl.cpp",
    "implementation/endpoints/src/local_client_endpoint_impl.cpp",
    "implementation/endpoints/src/local_tcp_client_endpoint_impl.cpp",
    "implementation/endpoints/src/local_tcp_server_endpoint_impl.cpp",
    "implementation/endpoints/src/local_uds_client_endpoint_impl.cpp",
    "implementation/endpoints/src/local_uds_server_endpoint_impl.cpp",
    "implementation/endpoints/src/netlink_connector.cpp",
    "implementation/endpoints/src/asio_netlink_factory.cpp",
]

VSOMEIP_ROUTING_LAYER_ROUTING_SRCS = [
    "implementation/routing/src/routing_manager_base.cpp",
    "implementation/routing/src/routing_manager_client.cpp",
    "implementation/routing/src/routing_manager_impl.cpp",
    "implementation/routing/src/routing_manager_stub.cpp",
]

# Only the application half of runtime_impl lives in the routing layer.
# `runtime_impl_apps.cpp` provides an `application_factory` implementation
# (owning the applications registry and constructing `application_impl`s)
# and a namespace-scope registrar that installs it into core's runtime_impl
# at library load. See `VSOMEIP_CORE_RUNTIME_SRCS` above and
# `implementation/runtime/include/application_factory.hpp`.
VSOMEIP_ROUTING_LAYER_RUNTIME_SRCS = [
    "implementation/runtime/src/application_impl.cpp",
    "implementation/runtime/src/runtime_impl_apps.cpp",
]

# `timer.cpp` wraps `boost::asio::steady_timer` behind
# `abstract_socket_factory` so unit tests can mock the timer. No production
# code path actually calls `vsomeip_v3::timer::create` — SD and the
# routing manager use `boost::asio::steady_timer` directly. Keeping it in
# core does no harm but bloats the core library with code that exists
# purely for test mocking, so we live it in the routing layer alongside
# the rest of the testable surface.
VSOMEIP_ROUTING_LAYER_TIMER_SRCS = [
    "implementation/endpoints/src/timer.cpp",
]

VSOMEIP_ROUTING_LAYER_SRCS = (
    VSOMEIP_ROUTING_LAYER_ENDPOINTS_SRCS +
    VSOMEIP_ROUTING_LAYER_ROUTING_SRCS +
    VSOMEIP_ROUTING_LAYER_RUNTIME_SRCS +
    VSOMEIP_ROUTING_LAYER_TIMER_SRCS
)

# =============================================================================
# Core vsomeip headers
# =============================================================================

cc_library(
    name = "vsomeip_hdrs",
    hdrs = VSOMEIP_PUBLIC_HDRS,
    includes = ["interface"],
    visibility = ["//visibility:private"],
)

cc_library(
    name = "vsomeip-internal-hdrs",
    hdrs = VSOMEIP_INTERNAL_HDRS,
    defines = VSOMEIP_DEFINES,
    include_prefix = "vsomeip",
    strip_include_prefix = "/",
    visibility = ["//visibility:public"],
    deps = [":vsomeip_hdrs"] + THIRD_PARTY_DEPS,
)

# =============================================================================
# Core vsomeip library — wire-level SOME/IP, no routing manager,
# no application_impl, no UDS IPC, no netlink.
# This is what `sd_host_lib` (and any future "SD-only" consumer) links
# against; it is also the static foundation that `:vsomeip-lib` layers
# the routing manager on top of.
# =============================================================================

cc_library(
    name = "vsomeip-core-lib",
    srcs = VSOMEIP_CORE_SRCS + select({
        ":is_multiple_routing_managers_enabled": [
            "implementation/configuration/src/configuration_impl.cpp",
        ],
        "//conditions:default": [],
    }),
    # Internal implementation headers are exposed via hdrs so downstream
    # consumers (notably the unit tests under //test/...) can include them
    # directly without re-declaring source dependencies.
    hdrs = VSOMEIP_INTERNAL_HDRS,
    copts = VSOMEIP_COPTS,
    defines = VSOMEIP_DEFINES + select({
        ":is_multiple_routing_managers_enabled": [
            "VSOMEIP_ENABLE_MULTIPLE_ROUTING_MANAGERS",
        ],
        "//conditions:default": [],
    }),
    includes = ["interface"],
    linkopts = VSOMEIP_LINKOPTS,
    linkstatic = False,
    visibility = ["//visibility:public"],
    deps = VSOMEIP_DEPS + [":vsomeip-internal-hdrs"],
)

cc_shared_library(
    name = "vsomeip3-core",
    # vsomeip-core transitively pulls in boost.* and spdlog (which itself
    # pulls in fmt). Mark them as exported by this shared library so the
    # downstream cc_shared_libraries that DT_NEEDED-depend on us
    # (`vsomeip3`, `vsomeip3-sd`, `vsomeip3-cfg`) know those symbols are
    # already resolved here and need not be re-bundled.
    exports_filter = [
        "@fmt",
        # Transitive libraries the boost.* deps above pull in. They are
        # linked statically into libvsomeip3-core.so, so the downstream
        # cc_shared_libraries that DT_NEEDED-depend on us (`vsomeip3`,
        # `vsomeip3-sd`, `vsomeip3-cfg`) must be told they are already
        # exported here — otherwise cc_shared_library flags them as
        # "linked statically by different cc_shared_libraries but not
        # exported".
        "@boost.asio//:asio_openssl",
        "@boost.asio",
        "@boost.coroutine",
        "@boost.context",
        "@boost.container",
        "@boost.chrono",
        "@boost.thread",
        "@boost.process",
        "@boost.filesystem",
        "@boost.serialization",
        "@openssl//:ssl",
        "@openssl//:crypto",
    ],
    deps = [":vsomeip-core-lib"],
)

# cc_import wrapper so external consumers can depend on libvsomeip3-core.so
# with one label. Consumers only get the pulic headers with this target.
cc_import(
    name = "vsomeip-core",
    shared_library = ":vsomeip3-core",
    deps = [":vsomeip_hdrs"],
)

# =============================================================================
# Full vsomeip library — vsomeip-core + routing manager + application_impl
# + UDS IPC + netlink. This is the surface that downstream tests and any
# normal vsomeip application links against.
# =============================================================================

cc_library(
    name = "vsomeip-lib",
    srcs = VSOMEIP_ROUTING_LAYER_SRCS,
    copts = VSOMEIP_COPTS,
    # MUST match vsomeip-core-lib: application_impl.cpp keys on
    # VSOMEIP_ENABLE_MULTIPLE_ROUTING_MANAGERS to construct configuration_impl
    # directly. Without it, init() takes the cfg-plugin dlopen path and aborts
    # ("Configuration module could not be loaded") -- breaking every full
    # vsomeip application (all the someip drivers).
    defines = VSOMEIP_DEFINES + select({
        ":is_multiple_routing_managers_enabled": [
            "VSOMEIP_ENABLE_MULTIPLE_ROUTING_MANAGERS",
        ],
        "//conditions:default": [],
    }),
    includes = ["interface"],
    linkopts = VSOMEIP_LINKOPTS,
    visibility = ["//visibility:public"],
    # Re-export `:vsomeip-core` so anything statically linking
    # `:vsomeip-lib` (the unit tests, downstream cc_binaries) gets both
    # tiers in one dep, matching the pre-split behaviour.
    #
    # `:vsomeip-internal-hdrs` is now listed explicitly here because the
    # `:vsomeip-core` cc_import deliberately does not propagates it
    deps = [
        ":vsomeip-core",
        ":vsomeip-internal-hdrs",
    ],
)

cc_shared_library(
    name = "vsomeip3",
    # libvsomeip3.so DT_NEEDED-loads libvsomeip3-core.so at runtime, so
    # the core objects are not duplicated into vsomeip3.so. Singletons
    # (`plugin_manager::get()`, logger globals, configuration impl)
    # therefore have exactly one home — `libvsomeip3-core.so.3` — across
    # vsomeip3.so / vsomeip3-sd.so / vsomeip3-cfg.so.
    dynamic_deps = [":vsomeip3-core"],
    deps = [":vsomeip-lib"],
)

# Public boundary for external vsomeip consumers.
cc_import(
    name = "vsomeip",
    shared_library = ":vsomeip3",
    deps = [
        ":vsomeip-core",
        ":vsomeip_hdrs",
    ],
)

# =============================================================================
# Configuration library (vsomeip-cfg)
# When --//:multiple_routing_managers_enabled=False this is the .so that
# applications dlopen to get a `configuration` implementation. When the
# flag is True, `configuration_impl.cpp` is folded into libvsomeip3-core.so
# instead and vsomeip3-cfg.so contains only `configuration_plugin_impl.cpp`.
# =============================================================================

VSOMEIP_CFG_SRCS = select({
    ":is_multiple_routing_managers_enabled": [
        "implementation/configuration/src/configuration_plugin_impl.cpp",
    ],
    "//conditions:default": [
        "implementation/configuration/src/configuration_impl.cpp",
        "implementation/configuration/src/configuration_plugin_impl.cpp",
    ],
})

cc_library(
    name = "vsomeip-cfg",
    srcs = VSOMEIP_CFG_SRCS,
    hdrs = VSOMEIP_INTERNAL_HDRS,
    copts = VSOMEIP_COPTS,
    defines = VSOMEIP_DEFINES,
    linkopts = VSOMEIP_LINKOPTS,
    # vsomeip-cfg only needs the core symbols (logger, plugin_manager,
    # configuration interface). The dlopen-time link is wired via
    # cc_shared_library.dynamic_deps below.
    deps = [
        ":vsomeip-core",
        ":vsomeip-internal-hdrs",
    ],
)

cc_shared_library(
    name = "vsomeip3-cfg-unversioned",
    dynamic_deps = [":vsomeip3-core"],
    user_link_flags = ["-Wl,-soname,libvsomeip3-cfg.so.3"],
    deps = [":vsomeip-cfg"],
)

# Create versioned library name that vsomeip expects
genrule(
    name = "vsomeip3-cfg",
    srcs = [":vsomeip3-cfg-unversioned"],
    outs = ["libvsomeip3-cfg.so.3"],
    cmd = "cp $(location :vsomeip3-cfg-unversioned) $@",
)

# =============================================================================
# Service Discovery library (vsomeip-sd)
#
# vsomeip-sd only needs symbols from vsomeip-core (logger, plugin_manager,
# the routing-data classes, udp_server_endpoint_impl, the configuration
# interface). DT_NEEDED against libvsomeip3-core.so.3 — never against
# libvsomeip3.so.3 — so a process that only links libvsomeip3-core.so +
# libvsomeip3-sd.so does not drag in the routing manager, application_impl,
# UDS IPC, or the netlink connector.
# =============================================================================

VSOMEIP_SD_SRCS = [
    "implementation/service_discovery/src/configuration_option_impl.cpp",
    "implementation/service_discovery/src/deserializer.cpp",
    "implementation/service_discovery/src/entry_impl.cpp",
    "implementation/service_discovery/src/eventgroupentry_impl.cpp",
    "implementation/service_discovery/src/ip_option_impl.cpp",
    "implementation/service_discovery/src/ipv4_option_impl.cpp",
    "implementation/service_discovery/src/ipv6_option_impl.cpp",
    "implementation/service_discovery/src/load_balancing_option_impl.cpp",
    "implementation/service_discovery/src/message_element_impl.cpp",
    "implementation/service_discovery/src/message_impl.cpp",
    "implementation/service_discovery/src/option_impl.cpp",
    "implementation/service_discovery/src/protection_option_impl.cpp",
    "implementation/service_discovery/src/remote_subscription_ack.cpp",
    "implementation/service_discovery/src/request.cpp",
    "implementation/service_discovery/src/runtime_impl.cpp",
    "implementation/service_discovery/src/selective_option_impl.cpp",
    "implementation/service_discovery/src/service_discovery_impl.cpp",
    "implementation/service_discovery/src/serviceentry_impl.cpp",
    "implementation/service_discovery/src/subscription.cpp",
    "implementation/service_discovery/src/unknown_option_impl.cpp",
]

cc_library(
    name = "vsomeip-sd-lib",
    srcs = VSOMEIP_SD_SRCS,
    hdrs = VSOMEIP_INTERNAL_HDRS,
    copts = VSOMEIP_COPTS,
    defines = VSOMEIP_DEFINES,
    include_prefix = "vsomeip",
    linkopts = VSOMEIP_LINKOPTS,
    deps = [
        ":vsomeip-core",
        ":vsomeip-internal-hdrs",
    ],
)

cc_shared_library(
    name = "vsomeip3-sd-unversioned",
    dynamic_deps = [":vsomeip3-core"],
    # Stamp DT_SONAME so the file produced here advertises the name the
    # plugin manager dlopens (`internal.hpp` → VSOMEIP_SD_LIBRARY) and the
    # genrule below renames it to. Any downstream binary that DT_NEEDED's
    # `:vsomeip-sd` then records the same string in its NEEDED slot,
    # which means service_discovery_impl::init()'s plugin_manager dlopen
    # finds the lib already loaded and just bumps the refcount — no
    # second mapping, no LD_LIBRARY_PATH search.
    user_link_flags = ["-Wl,-soname,libvsomeip3-sd.so.3"],
    deps = [":vsomeip-sd-lib"],
)

# Create versioned library name that vsomeip expects
genrule(
    name = "vsomeip3-sd",
    srcs = [":vsomeip3-sd-unversioned"],
    outs = ["libvsomeip3-sd.so.3"],
    cmd = "cp $(location :vsomeip3-sd-unversioned) $@",
)

cc_import(
    name = "vsomeip-sd",
    shared_library = ":vsomeip3-sd",
    deps = [
        ":vsomeip-core",
        ":vsomeip-internal-hdrs",
    ],
)

# =============================================================================
# E2E Protection library (vsomeip-e2e)
#
# e2e is loaded by the routing manager (see `routing_manager_impl::init`),
# so it lives in the full-vsomeip world and DT_NEEDED's libvsomeip3.so.3
# rather than libvsomeip3-core.so.3.
# =============================================================================

