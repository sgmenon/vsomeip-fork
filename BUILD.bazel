# Create versioned library name that vsomeip expects
genrule(
    name = "vsomeip3-e2e",
    srcs = [":vsomeip3-e2e-unversioned"],
    outs = ["libvsomeip3-e2e.so.3"],
    cmd = "cp $(location :vsomeip3-e2e-unversioned) $@",
