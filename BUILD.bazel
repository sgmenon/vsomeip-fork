    copts = VSOMEIP_COPTS,
    defines = VSOMEIP_DEFINES,
    linkopts = VSOMEIP_LINKOPTS,
    deps = [":vsomeip-lib"],
)

cc_shared_library(
    name = "vsomeip3-e2e-unversioned",
    dynamic_deps = [":vsomeip3"],
    user_link_flags = ["-Wl,-soname,libvsomeip3-e2e.so.3"],
    deps = [":vsomeip-e2e"],
