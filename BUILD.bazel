# =============================================================================
# Source file collections
#
# The source tree is partitioned into two tiers:
#
#   1. **vsomeip-core** — everything a non-routing process needs to talk
#      SOME/IP on the wire: network endpoints (TCP/UDP), serializer,
#      message classes, logger, plugin manager, protocol commands,
#      security primitives, tracing, utility, the runtime *factory*
#      (without `application_impl`), and the routing-data classes
#      (`event`, `eventgroupinfo`, `serviceinfo`, `remote_subscription`)
#      that the SD layer hands around as `shared_ptr<>`.
#      `configuration_impl.cpp` is folded in when
#      `--//:multiple_routing_managers_enabled=True` (the default), à la
#      upstream CMake's `VSOMEIP_ENABLE_MULTIPLE_ROUTING_MANAGERS=1`.
#
#   2. **vsomeip-routing-layer** — sources that exist only when this
#      process is acting as a full vsomeip application or routing
#      manager: the four `routing_manager_*` translation units,
#      `application_impl`, the UDS / local-TCP IPC endpoints, the
#      netlink connector, peer-credential check, and the endpoint
#      manager (base + impl) that wires them all together.
#
# `:vsomeip-lib` is the union of the two tiers and is wrapped by the
# regular `libvsomeip3.so` (`:vsomeip3` cc_shared_library), preserving
# the open-source shape for downstream consumers and the test suite.
#
# Source lists are explicit (no `*.cpp` globs) so that the partition is
# trivially auditable and a new file appearing under
# `implementation/` does not silently land in `libvsomeip3-core.so`.
# =============================================================================

# Public interface headers
VSOMEIP_PUBLIC_HDRS = glob([
    "interface/vsomeip/*.hpp",
    "interface/vsomeip/*.h",
    "interface/vsomeip/**/*.hpp",
])

# Internal headers (included as srcs since they use relative paths).
# These are still globbed because headers are not on the symbol/link
# critical path — adding a new header to an existing subtree is benign.
VSOMEIP_INTERNAL_HDRS = glob(
    [
        "implementation/configuration/include/*.hpp",
        "implementation/endpoints/include/*.hpp",
        "implementation/logger/include/*.hpp",
        "implementation/message/include/*.hpp",
        "implementation/plugin/include/*.hpp",
        "implementation/protocol/include/*.hpp",
        "implementation/routing/include/*.hpp",
        "implementation/runtime/include/*.hpp",
        "implementation/security/include/*.hpp",
        "implementation/tracing/include/*.hpp",
        "implementation/utility/include/*.hpp",
        "implementation/e2e_protection/include/**/*.hpp",
        "implementation/service_discovery/include/**/*.hpp",
    ],
    exclude = [
        "implementation/configuration/include/internal.hpp.in",
    ],
)

